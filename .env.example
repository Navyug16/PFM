# PFM Supabase Environment Configurations
# Copy this file to .env and configure your variables locally.

# The public URL of your Supabase project (found in Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# The public anonymous client API key (found in Project Settings > API)
# DO NOT expose your service_role key here, as this runs in the browser.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
